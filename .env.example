# Copy to .env and fill in. .env is gitignored — never commit real values.
# On GitHub these four go in Settings -> Secrets and variables -> Actions.

# BotFather -> /newbot (or /revoke to rotate an exposed one)
TELEGRAM_BOT_TOKEN=

# Message your bot, then: python -m notifier --get-chat-id
TELEGRAM_CHAT_ID=

# https://developer.ticketmaster.com/  (Discovery API, issued instantly)
TICKETMASTER_API_KEY=

# https://console.anthropic.com/
ANTHROPIC_API_KEY=
